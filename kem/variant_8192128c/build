#!/bin/sh
gcc -O3 -march=native -mtune=native -Wall -Wextra -Wno-unused-function -Wno-unused-parameter -Wno-sign-compare -I. -I../common/core -Isubroutines -DKAT -DKATNUM=`cat KATNUM` -DCT_PER_SK=${CT_PER_SK:-`cat KATNUM`} "-DCRYPTO_NAMESPACE(x)=x" "-D_CRYPTO_NAMESPACE(x)=_##x" -o kat ../common/kat_kem_vectors.c nist/rng.c ../common/core/controlbits.c ../common/core/encrypt.c gf.c ../common/core/operations.c ../common/core/pk_gen.c ../common/core/root.c ../common/core/sk_gen.c util.c -lkeccak -lcrypto -ldl
